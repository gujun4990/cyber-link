{
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devPath": "http://127.0.0.1:5173",
    "distDir": "../dist"
  },
  "package": {
    "productName": "CyberControl_HA_Client",
    "version": "0.1.24"
  },
  "tauri": {
    "allowlist": {
      "all": true
    },
    "systemTray": {
      "iconPath": "icons/icon.png"
    },
    "bundle": {
      "active": true,
      "icon": [
        "icons/icon.ico",
        "icons/icon.png"
      ],
      "identifier": "com.cyber-link.app",
      "windows": {
        "webviewInstallMode": {
          "type": "embedBootstrapper",
          "silent": true
        },
        "nsis": {
          "installMode": "currentUser"
        }
      }
    },
    "windows": [
      {
        "label": "main",
        "title": "CyberControl HA Client",
        "visible": false,
        "resizable": true
      }
    ]
  }
}
